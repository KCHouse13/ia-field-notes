      <!-- Part 4: Try It Yourself -->
      <h3 class="cgb-group-heading fade-in">Try it yourself</h3>
      <p class="fade-in" style="color:var(--text-secondary);font-size:0.92rem;margin-bottom:1.25rem;">Read each scenario, write your own prompt, then click to see our suggestion.</p>

      <div class="practice-grid fade-in">

        <div class="practice-card fade-in">
          <div class="practice-body">
            <div class="practice-icon">✉️</div>
            <div style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.25rem;">Scenario 1</div>
            <h4>Buyer Meeting Follow-Up</h4>
            <div class="practice-challenge">Challenge: Write a prompt that gets Copilot to draft a professional follow-up email to the buyer.</div>
