    align-items: center;
    justify-content: center;
  }
  .cgb-back-to-top.visible { opacity: 1; pointer-events: all; }
  .cgb-back-to-top:hover { transform: translateY(-2px); }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .gcse-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; padding: 1.25rem; }
    .evolve-tabs { flex-direction: column; }
    .evolve-tab:first-child { border-radius: 10px 10px 0 0; }
    .evolve-tab:last-child  { border-radius: 0; }
    .evolve-tab + .evolve-tab { border-left: 1px solid var(--border); border-top: none; }
    .practice-grid { grid-template-columns: 1fr; }
    .cheat-sheet { padding: 1.25rem; }
    .cgb-container { padding: 0 1.25rem; }
    section { padding: 2.5rem 0; }
