  .access-sub { grid-area: sub; align-self: start; color: var(--text-meta); font-size: 0.78rem; line-height: 1.3; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* ── Lightbox (static shell) ── */
