  }
  .checklist-checkbox.checked { background: var(--accent); border-color: var(--accent); }
  .checklist-checkbox.checked::after { content: '✓'; color: #fff; font-size: 0.75rem; font-weight: 700; }
  .checklist-text { flex: 1; }
  .checklist-title { font-weight: 600; font-size: 0.92rem; margin-bottom: 0.15rem; }
  .checklist-desc { font-size: 0.82rem; color: var(--text-secondary); }
  .congrats-msg {
    display: none;
    text-align: center;
    padding: 2rem;
