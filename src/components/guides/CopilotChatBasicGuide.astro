  .evolve-badge { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.7rem; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.04em; }
  .evolve-badge.good    { background: #fef9c3; color: #854d0e; }
  .evolve-badge.better  { background: #ffedd5; color: #9a3412; }
