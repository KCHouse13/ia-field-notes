  }
  .evolve-tab:first-child { border-radius: 10px 0 0 0; }
  .evolve-tab:last-child  { border-radius: 0 10px 0 0; }
  .evolve-tab + .evolve-tab { border-left: none; }
  .evolve-tab:hover { background: var(--bg-raised); }
  .evolve-tab.active { color: var(--text-primary); background: var(--bg-raised); border-bottom-color: transparent; }
  .evolve-tab.active::after { content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 2px; }
  .evolve-tab[data-level="good"].active::after    { background: #eab308; }
  .evolve-tab[data-level="better"].active::after  { background: #f97316; }
  .evolve-tab[data-level="best"].active::after    { background: #22c55e; }
  .evolve-tab .evolve-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 0.4rem; vertical-align: middle; }
  .evolve-tab[data-level="good"]   .evolve-dot { background: #eab308; }
  .evolve-tab[data-level="better"] .evolve-dot { background: #f97316; }
  .evolve-tab[data-level="best"]   .evolve-dot { background: #22c55e; }
  .evolve-panel-wrap {
    background: var(--bg-surface);
    border: 1px solid var(--border);
