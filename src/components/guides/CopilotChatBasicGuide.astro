  .highlight-goal { background: rgba(59, 130, 246, 0.18); border-radius: 3px; padding: 1px 4px; }
  .highlight-context { background: rgba(168, 85, 247, 0.18); border-radius: 3px; padding: 1px 4px; }
  .highlight-source { background: rgba(249, 115, 22, 0.18); border-radius: 3px; padding: 1px 4px; }
  .highlight-expectations { background: rgba(34, 197, 94, 0.18); border-radius: 3px; padding: 1px 4px; }
  [data-theme="dark"] .highlight-goal { background: rgba(96, 165, 250, 0.20); color: #93bbfc; }
  [data-theme="dark"] .highlight-context { background: rgba(192, 132, 252, 0.20); color: #d4b5fd; }
  [data-theme="dark"] .highlight-source { background: rgba(251, 146, 60, 0.20); color: #fdba74; }
  [data-theme="dark"] .highlight-expectations { background: rgba(74, 222, 128, 0.20); color: #86efac; }

  /* ── Prompt evolution stepper ── */
  .evolve-stepper { margin-bottom: 2rem; }
  .evolve-tabs { display: flex; gap: 0; margin-bottom: 0; position: relative; }
