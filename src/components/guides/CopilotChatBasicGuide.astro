  .congrats-msg.visible { display: block; }
  .congrats-msg .congrats-emoji { font-size: 2rem; display: block; margin-bottom: 0.5rem; }

  /* ── Resources grid ── */
  .resources-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .resource-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.25s, border-color 0.25s, transform 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
    position: relative;
    overflow: hidden;
  }
  .resource-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .resource-card:hover::before { transform: scaleX(1); }
  .resource-card:hover { box-shadow: var(--shadow-card-hover); border-color: var(--border-strong); transform: translateY(-2px); color: inherit; }
  .resource-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
  .resource-card h4 { font-family: var(--font-body); font-weight: 600; font-size: 0.95rem; margin-bottom: 0.35rem; }
  .resource-card p { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.5; }
  .resource-card .ext-icon { position: absolute; top: 1rem; right: 1rem; color: var(--text-secondary); font-size: 0.85rem; }

  /* ── Toast ── */
  .cgb-toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--bg-surface);
    border: 1px solid var(--accent);
    color: var(--text-primary);
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-size: 0.85rem;
