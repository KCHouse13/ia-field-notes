  /* ── Checklist ── */
  .progress-bar-wrapper { background: var(--bg-raised); border-radius: 100px; height: 8px; margin-bottom: 2rem; overflow: hidden; }
  .progress-bar { height: 100%; background: var(--accent); border-radius: 100px; transition: width 0.4s ease; width: 0%; }
  .progress-label { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-meta); margin-bottom: 0.5rem; }
  .checklist { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s, box-shadow 0.25s, background 0.2s;
    cursor: pointer;
  }
  .checklist-item:hover { border-color: var(--border-strong); box-shadow: var(--shadow-card-hover); }
  .checklist-item.completed { opacity: 0.7; }
  .checklist-checkbox {
    width: 22px;
    height: 22px;
    border: 2px solid var(--border-strong);
    border-radius: 6px;
    flex-shrink: 0;
    margin-top: 0.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
