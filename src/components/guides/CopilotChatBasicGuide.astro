---
// Self-contained interactive guide: "Copilot Chat (Basic)".
// Ported from a standalone HTML guide into a scoped Astro component so it
// integrates natively with the site (shared header/footer, theme, fonts, search).
// - All colliding base classes are namespaced with `cgb-` to avoid global.css bleed.
// - Main CSS uses Astro scoped styles; dynamically-injected lightbox markup is
//   styled by a small `is:global` block under `.cgb-root`.
// - Theme is owned by the site (BaseLayout); the guide ships no theme toggle.
const IMG = '/images/guides/copilot-chat-basic';
---

<div class="cgb-root">
  <!-- ── Guide sub-navigation (sticky under the 56px site header) ── -->
  <nav class="cgb-subnav" aria-label="Guide sections" data-pagefind-ignore>
    <div class="cgb-container cgb-subnav-inner">
      <span class="cgb-subnav-brand"><span class="cgb-subnav-dot" aria-hidden="true">CC</span>Copilot Chat · Basic</span>
      <ul class="cgb-subnav-links" role="list">
        <li><a href="#overview">Overview</a></li>
        <li><a href="#capabilities">Capabilities</a></li>
        <li><a href="#prompting">Prompting</a></li>
        <li><a href="#scenarios">Scenarios</a></li>
        <li><a href="#get-started">Get started</a></li>
      </ul>
    </div>
  </nav>
  <div class="cgb-scroll-progress" id="cgb-scroll-progress"></div>

  <!-- ── Hero ── -->
  <header class="cgb-hero">
    <div class="cgb-container cgb-hero-content">
      <p class="cgb-hero-stamp fade-in">Interactive Guide · Microsoft 365</p>
      <h1 class="fade-in">Copilot Chat<br><span style="font-size:0.55em; display:inline-block; background:var(--accent-subtle); border:1px solid var(--accent); padding:0.1em 0.6em; border-radius:999px; font-style:italic; color:var(--accent); vertical-align:middle; margin-top:-0.15em;">basic</span></h1>
      <p class="cgb-hero-tagline fade-in" style="font-size:1.4rem; max-width:600px; margin-bottom:1rem;">Overview and Getting Started Guide</p>
      <p class="cgb-hero-tagline fade-in" style="margin-top:0;">The secure AI workspace included with your Microsoft 365 subscription. No additional license required.</p>
      <div class="cgb-hero-ctas fade-in">
        <a href="#overview" class="cgb-btn-primary">Start the Guide →</a>
        <a href="#capabilities" class="cgb-btn-ghost">See capabilities ↓</a>
      </div>
    </div>
  </header>

  <!-- ── Overview ── -->
  <section id="overview">
    <div class="cgb-container">
      <p class="cgb-section-label fade-in">The Overview</p>
      <h2 class="cgb-section-title fade-in">Your secure AI workspace</h2>
      <p class="cgb-section-intro fade-in">
        Copilot Chat is a secure AI chat experience available at no additional cost for Entra account users with eligible Microsoft 365 subscriptions. It's grounded in web data and protected by Enterprise Data Protection (EDP).
      </p>

      <div class="callout callout-note fade-in" style="max-width:700px; margin-left:auto; margin-right:auto;">
        <div class="callout-title cgb-edp-title">Enterprise Data Protection <svg class="cgb-edp-shield" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false"><path d="M12 2.2 4.5 5.1v6.1c0 4.6 3.2 8.9 7.5 10.6 4.3-1.7 7.5-6 7.5-10.6V5.1L12 2.2Z" fill="#107c41"/><path d="m8.6 12.1 2.3 2.3 4.5-4.6" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        When you see the <strong>green shield icon</strong> in Copilot Chat, it means EDP is applied. Prompts and responses are processed within the Microsoft 365 service boundary, and they are not used to train foundation models, including work content you add or upload.
      </div>

      <h3 style="font-size:1.2rem; margin:2rem 0 1rem;" class="fade-in">Where to access Copilot Chat</h3>
      <div class="access-grid fade-in">
        <a href="https://m365copilot.com" target="_blank" rel="noopener" class="access-item"><span class="access-icon">🌐</span><span class="access-title">m365copilot.com</span><span class="access-sub">(primary web)</span><span class="access-action">Open</span></a>
        <div class="access-item" onclick="openLightbox('copilot-edge-sidebar.png','Copilot Chat in Microsoft Edge — open the sidebar to access Chat alongside any webpage')"><span class="access-icon">🔲</span><span class="access-title">Microsoft Edge</span><span class="access-sub">(sidebar)</span><span class="access-action">Preview</span></div>
        <div class="access-item" onclick="openLightbox('copilot-outlook.png','Copilot Chat in Outlook — available in the side pane alongside your email')"><span class="access-icon">📧</span><span class="access-title">Outlook</span><span class="access-sub">(left nav / side pane)</span><span class="access-action">Preview</span></div>
        <div class="access-item" onclick="openLightboxQR()"><span class="access-icon">📱</span><span class="access-title">Mobile app</span><span class="access-sub">(iOS &amp; Android)</span><span class="access-action">QR Code</span></div>
        <div class="access-item" onclick="openLightboxTeams()"><span class="access-icon">💬</span><span class="access-title">Teams</span><span class="access-sub">(left nav)</span><span class="access-action">Preview</span></div>
        <div class="access-item" onclick="openLightbox('copilot-desktop-app.png','M365 Copilot desktop app — look for the Copilot icon in your Windows taskbar','desktop')"><span class="access-icon">💻</span><span class="access-title">M365 Copilot</span><span class="access-sub">(desktop app)</span><span class="access-action">Preview</span></div>
      </div>

      <div class="guide-hero-image fade-in" onclick="openLightbox('copilot-chat-annotated.png','Copilot Chat interface — click or pinch to zoom into the 14 annotated features')" style="cursor:pointer;" title="Click to enlarge">
        <img src={`${IMG}/copilot-chat-annotated.png`} alt="Annotated screenshot of the Copilot Chat interface showing 14 numbered features: 1-New chat, 2-Search, 3-Library, 4-Agents, 5-Chat history, 6-Prompt box, 7-File upload, 8-Voice, 9-Prompt starters, 10-Saved prompts, 11-Enterprise protection shield, 12-New chat button, 13-Model selector, 14-App launcher" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ── Lightbox overlay (shared) ── -->
  <div class="lightbox-overlay" id="cgb-lightbox" onclick="closeLightbox(event)">
    <div class="lightbox-content" id="cgb-lightbox-content">
      <button class="lightbox-close" onclick="closeLightbox(event)" aria-label="Close">&times;</button>
      <div id="cgb-lightbox-body"></div>
      <div class="lightbox-caption" id="cgb-lightbox-caption"></div>
    </div>
  </div>

  <!-- ── Capabilities ── -->
  <section id="capabilities">
    <div class="cgb-container">
      <p class="cgb-section-label fade-in">The Capabilities</p>
      <h2 class="cgb-section-title fade-in">Capabilities at a glance</h2>
      <p class="cgb-section-intro fade-in">Every feature below is available to you today with your existing Microsoft 365 subscription. Click any card to see an example prompt.</p>

      <!-- Personalization & Customization -->
      <div class="capability-category">
        <h3 class="fade-in">Personalization &amp; Customization</h3>
        <div class="capabilities-grid two-col">

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">⚙️</div>
              <div class="capability-info"><h4>Custom Instructions</h4><p class="capability-desc">Tell Copilot how you want it to respond — every time, automatically</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <p style="font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:0.75rem;">Custom instructions let you set persistent preferences that apply to every conversation. Think of it as training Copilot on your working style — you set it once, and every response reflects your preferences.</p>
              <p style="font-size:0.85rem;color:var(--text-secondary);line-height:1.6;margin-bottom:0.5rem;"><strong style="color:var(--text-primary);">How to set up:</strong></p>
              <ol style="font-size:0.85rem;color:var(--text-secondary);line-height:1.7;padding-left:1.25rem;margin-bottom:0.75rem;">
                <li>Click the <strong>⋯ menu</strong> (top right) → <strong>Settings</strong></li>
                <li>Go to <strong>Personalization</strong></li>
                <li>Toggle on <strong>Custom instructions</strong> and click <strong>Edit instructions</strong></li>
                <li>Type your preferences or click the suggested chips to add common ones</li>
                <li>Click <strong>Save instructions</strong></li>
              </ol>
              <img src={`${IMG}/copilot-custom-instructions.png`} alt="Custom Instructions settings showing personalization options and instruction editor" style="border-radius:8px;border:1px solid var(--border);margin-top:0.5rem;" class="cgb-zoomable" title="Click to enlarge" onclick="openLightbox('copilot-custom-instructions.png','Custom instructions — set persistent preferences under Settings → Personalization that apply to every conversation')" />
              <div class="callout callout-tip" style="margin-top:1rem;">
                <div class="callout-title">💡 Tip</div>Be specific about your role and preferences. Instead of "be helpful," try: <em>"I'm a CPG sales rep. Keep responses concise and action-oriented. Focus on retail buyer conversations and category management."</em>
              </div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">🧠</div>
              <div class="capability-info"><h4>Saved Memories</h4><p class="capability-desc">Copilot remembers details you share to personalize future responses</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <p style="font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:0.75rem;">Memories let Copilot learn context about you over time — your accounts, your role, your goals — so it can give more relevant answers without you repeating yourself every conversation.</p>
              <p style="font-size:0.85rem;color:var(--text-secondary);line-height:1.6;margin-bottom:0.5rem;"><strong style="color:var(--text-primary);">How to add a memory:</strong></p>
              <ol style="font-size:0.85rem;color:var(--text-secondary);line-height:1.7;padding-left:1.25rem;margin-bottom:0.5rem;">
                <li>In any chat, tell Copilot: <em>"Add the following to memory: [your context]"</em></li>
                <li>Copilot will confirm with a <strong>"Memory updated"</strong> indicator</li>
                <li>Future conversations will automatically use this context</li>
              </ol>
              <p style="font-size:0.85rem;color:var(--text-secondary);line-height:1.6;margin-bottom:0.75rem;"><strong style="color:var(--text-primary);">How to manage memories:</strong> Go to <strong>⋯ menu → Settings → Personalization → Manage saved memories</strong> to review, edit, or delete what Copilot remembers.</p>
              <img src={`${IMG}/copilot-memories.png`} alt="Saved memories showing how to add context and manage memories in settings" style="border-radius:8px;border:1px solid var(--border);margin-top:0.5rem;" class="cgb-zoomable" title="Click to enlarge" onclick="openLightbox('copilot-memories.png','Saved memories — add context in chat and manage what Copilot remembers under Settings → Personalization')" />
              <div class="callout callout-tip" style="margin-top:1rem;">
                <div class="callout-title">💡 Tip</div>Great things to save as memories: your key accounts, your role and team, the products you sell, your preferred communication style, and recurring meeting cadences. The more Copilot knows about your work, the less prompting you need.
              </div>
            </div></div>
          </div>

        </div>
      </div>

      <!-- Core Chat -->
      <div class="capability-category">
        <h3 class="fade-in">Core Chat</h3>
        <div class="capabilities-grid">

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">💬</div>
              <div class="capability-info"><h4>Web-grounded Q&amp;A</h4><p class="capability-desc">Ask questions answered from internet data in real time</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">What are the top 3 consumer trends driving growth in the snack food category for 2026?<span class="copy-hint">Click to copy</span></div></div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">🔄</div>
              <div class="capability-info"><h4>Multi-turn Conversations</h4><p class="capability-desc">Refine and build on answers across follow-up messages</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Now compare those trends to what private label brands are doing differently in the same category<span class="copy-hint">Click to copy</span></div></div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">🧠</div>
              <div class="capability-info"><h4>Model Selection</h4><p class="capability-desc">Choose between Auto, Quick Response, or Think Deeper modes</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Think deeper: What are the second-order effects of GLP-1 weight loss medications on snacking occasions and CPG portfolio strategy?<span class="copy-hint">Click to copy</span></div></div>
              <div class="capability-images">
                <div class="cap-img-item" onclick="openLightbox('model-selector-1.png','Model selector — Auto, Quick Response, Think Deeper, plus Claude Opus and GPT model families')">
                  <img src={`${IMG}/model-selector-1.png`} alt="Model selector dropdown showing Auto, Quick Response, Think Deeper, Opus, and GPT options" loading="lazy" />
                  <div class="cap-img-label">Model selector</div>
                </div>
              </div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">📝</div>
              <div class="capability-info"><h4>Summarize Content</h4><p class="capability-desc">Paste any text and get a structured summary instantly</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Summarize the following trade publication article in 3 bullet points with implications for our retail strategy: [paste text]<span class="copy-hint">Click to copy</span></div></div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">✏️</div>
              <div class="capability-info"><h4>Rewrite &amp; Improve</h4><p class="capability-desc">Polish your writing for clarity, tone, and impact</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Rewrite this buyer presentation talking point to be more concise and data-driven: [paste text]<span class="copy-hint">Click to copy</span></div></div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">🌐</div>
              <div class="capability-info"><h4>Translate</h4><p class="capability-desc">Translate content between languages</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Translate this product packaging copy into Spanish for our Hispanic market expansion, keeping a friendly and appetizing tone<span class="copy-hint">Click to copy</span></div></div>
            </div></div>
          </div>

        </div>
      </div>

      <!-- Files & Content -->
      <div class="capability-category">
        <h3 class="fade-in">Files &amp; Content</h3>
        <div class="capabilities-grid">

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">📎</div>
              <div class="capability-info"><h4>Upload Files</h4><p class="capability-desc">Upload documents, images, or data files via the '+' button for analysis</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Summarize the key findings and action items from this quarterly business review deck<span class="copy-hint">Click to copy</span></div></div>
              <div class="capability-images">
                <div class="cap-img-item" onclick="openLightbox('file-upload-plus.png','The + button menu — Add work content, upload images and files, attach cloud files, Designer, Compose (Word/Excel/PowerPoint), All agents')">
                  <img src={`${IMG}/file-upload-plus.png`} alt="File upload menu showing Add work content, Upload images and files, Attach cloud files, Designer, Compose with Word/Excel/PowerPoint submenu, All agents" loading="lazy" />
                  <div class="cap-img-label">'+' button menu</div>
                </div>
              </div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">📂</div>
              <div class="capability-info"><h4>Reference Files (ContextIQ)</h4><p class="capability-desc">Type '/' to select files from your Microsoft 365 content</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">/Q2-Kroger-Scorecard.xlsx — Which SKUs are underperforming versus plan and what's driving the gap?<span class="copy-hint">Click to copy</span></div></div>
              <div class="capability-images">
                <div class="cap-img-item" onclick="openLightbox('file-contextiq-slash.png','Type / in the prompt box to search and reference your recently opened files directly in the conversation')">
                  <img src={`${IMG}/file-contextiq-slash.png`} alt="ContextIQ file picker showing recent documents like Word files and PowerPoint presentations with a search bar" loading="lazy" />
                  <div class="cap-img-label">'/' file reference</div>
                </div>
              </div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">🎨</div>
              <div class="capability-info"><h4>Image Generation</h4><p class="capability-desc">Create images from text descriptions</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Create a professional banner image for our annual sales kickoff meeting with the theme 'Fueling Growth Together'<span class="copy-hint">Click to copy</span></div></div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">🔍</div>
              <div class="capability-info"><h4>Image Analysis</h4><p class="capability-desc">Upload images and ask questions about them</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">What does this planogram photo show? Identify any compliance issues with our brand's shelf placement<span class="copy-hint">Click to copy</span></div></div>
            </div></div>
          </div>

        </div>
      </div>

      <!-- Copilot Pages -->
      <div class="capability-category">
        <h3 class="fade-in">Copilot Pages</h3>
        <div class="capabilities-grid two-col">

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">📄</div>
              <div class="capability-info"><h4>Create Pages</h4><p class="capability-desc">Convert any Copilot response into an editable, shareable document</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Draft a project status update for my team<span class="copy-hint">Click to copy</span></div></div>
              <p style="font-size:0.85rem;color:var(--text-meta);margin-top:0.5rem;">Then click "Edit in Pages" on the response</p>
              <img src={`${IMG}/copilot-pages-edit.png`} alt="Copilot response showing the Edit in Pages button" style="margin-top:0.75rem;border-radius:8px;border:1px solid var(--border);" class="cgb-zoomable" title="Click to enlarge" onclick="openLightbox('copilot-pages-edit.png','Create Pages — turn any Copilot response into an editable document with the Edit in Pages button')" />
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">👥</div>
              <div class="capability-info"><h4>Collaborate on Pages</h4><p class="capability-desc">Share Pages with colleagues for real-time co-editing</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <p style="font-size:0.88rem;color:var(--text-secondary);margin-top:0.75rem;">Share any Copilot Page with your team for real-time collaborative editing — just like a shared document.</p>
              <img src={`${IMG}/copilot-pages-view.png`} alt="Copilot Page in editing view with sharing and collaboration" style="margin-top:0.75rem;border-radius:8px;border:1px solid var(--border);" class="cgb-zoomable" title="Click to enlarge" onclick="openLightbox('copilot-pages-view.png','Collaborate on Pages — share a Copilot Page for real-time co-editing, just like a shared document')" />
            </div></div>
          </div>

        </div>
      </div>

      <!-- Copilot in Apps -->
      <div class="capability-category">
        <h3 class="fade-in">Copilot in your everyday apps</h3>
        <div class="capabilities-grid two-col">

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">💬</div>
              <div class="capability-info"><h4>Chat in Teams</h4><p class="capability-desc">Copilot Chat opens in the Teams left nav, aware of your open chat or channel</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">
              <div class="prompt-example"><span class="prompt-label">Try this prompt:</span><div class="prompt-text" onclick="copyPrompt(this)">Summarize the key decisions from today's channel planning thread and list any action items assigned to me<span class="copy-hint">Click to copy</span></div></div>
              <div class="capability-images">
                <div class="cap-img-item cap-img-wide" onclick="openLightbox('copilot-teams-open-and-closed.png','Copilot Chat in Teams - click the Copilot icon in the left nav to open or collapse the Copilot Chat pane')">
                  <img src={`${IMG}/copilot-teams-open-and-closed.png`} alt="Teams showing the Copilot icon in the left nav and the Copilot Chat pane open" loading="lazy" />
                  <div class="cap-img-label">Open and collapse Copilot Chat from the Teams left nav</div>
                </div>
              </div>
            </div></div>
          </div>

          <div class="capability-card fade-in">
            <div class="capability-header" onclick="toggleCapability(this)">
              <div class="capability-icon">📧</div>
              <div class="capability-info"><h4>Chat in Outlook</h4><p class="capability-desc">Copilot Chat opens alongside your email — summarize threads, get insights, and draft replies</p></div>
              <div class="expand-icon">+</div>
            </div>
            <div class="capability-detail"><div class="capability-detail-inner">

