---
interface Props {
  title: string;
  slug: string;
  date: string;
  topic?: string;
  description?: string;
  collection?: string;
  readTime?: string;
}

const { title, slug, date, topic, description, collection = 'field-notes', readTime = '5 min read' } = Astro.props;
const d = new Date(date);
const formattedDate = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<a href={`/${collection}/${slug}/`} class="field-note-card block">
  {topic && <span class="topic-badge">{topic}</span>}

  <h3 class="card-title">{title}</h3>

  {description && <p class="card-description">{description}</p>}

  <footer class="card-footer">
    <time datetime={d.toISOString()}>{formattedDate}</time>
    {readTime && <span>{readTime}</span>}
  </footer>
</a>

<style>
  .field-note-card {
    position: relative;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow-card);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s ease-out, box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
  }

  .field-note-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-card-hover);
  }

  .topic-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-subtle);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .card-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.78rem;
    color: var(--text-meta);
  }
</style>
