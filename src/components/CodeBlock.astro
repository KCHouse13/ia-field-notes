---
interface Props {
  lang: string;
  filename?: string;
  code: string;
}

const { lang, filename, code } = Astro.props;
---

<div class="my-6 rounded-lg overflow-hidden border" style="border-color: var(--border);">
  {filename && (
    <div class="flex items-center gap-2 px-4 py-2 text-xs font-medium" style="background-color: #2D2D2D; color: #9D9D9D;">
      <span>{filename}</span>
      <span class="ml-auto uppercase opacity-60">{lang}</span>
    </div>
  )}

  <div class="relative" style="background-color: #1E1E1E;">
    {!filename && (
      <span class="absolute top-2 right-12 text-xs uppercase opacity-40" style="color: #9D9D9D;">{lang}</span>
    )}
    <pre class="p-4 sm:p-5 overflow-x-auto text-sm leading-relaxed"><code class={`language-${lang}`} style="font-family: 'Commit Mono', monospace; color: #D4D4D4;">{code}</code></pre>
    <button
      type="button"
      class="absolute top-3 right-3 p-1.5 rounded-md text-xs transition-opacity hover:opacity-80"
      style="background-color: #2D2D2D; color: #9D9D9D;"
      aria-label="Copy code"
      data-copy-code
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('[data-copy-code]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const code = btn.closest('.relative')?.querySelector('code');
      if (code) {
        navigator.clipboard.writeText(code.textContent ?? '');
        const orig = btn.innerHTML;
        btn.innerHTML = '<span class="text-xs px-1">✓</span>';
        setTimeout(() => { btn.innerHTML = orig; }, 1500);
      }
    });
  });
</script>
