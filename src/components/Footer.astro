---
const now = new Date();
const year = now.getFullYear();
const startOfYear = new Date(year, 0, 1);
const dayOfYear = Math.ceil((now.getTime() - startOfYear.getTime()) / 86400000);
const weekNum = Math.ceil(dayOfYear / 7);
const weekStr = `${year}-W${String(weekNum).padStart(2, '0')}`;
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <p class="footer-name">IA Field Notes</p>
      <p class="footer-tagline">Intelligence, amplified</p>
      <p class="footer-disclaimer">Not an official Microsoft resource. Views represent personal perspective from work in the field. Nothing here is sponsored, endorsed, or reviewed by any vendor.</p>
      <div class="footer-links">
        <a href="/about/">About</a>
        <a href="https://github.com/KCHouse13/ia-field-notes">GitHub</a>
        <a href="mailto:hello@intelligenceamplified.work">Contact</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    LAST UPDATED · {weekStr}
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-brand {
    max-width: 520px;
    text-align: center;
  }

  .footer-name {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .footer-disclaimer {
    font-size: 0.78rem;
    color: var(--text-meta);
    line-height: 1.55;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .footer-links a {
    font-size: 0.82rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.12s ease;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    text-align: center;
    font-family: 'Commit Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-meta);
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .footer-brand { max-width: 100%; }
  }
</style>
