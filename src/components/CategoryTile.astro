---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  countText?: string;
}

const { title, description, href, icon, countText } = Astro.props;
---

<a href={href} class="category-tile">
  {icon && <div class="tile-icon">{icon}</div>}

  <h3 class="tile-title">{title}</h3>

  <p class="tile-description">{description}</p>

  {countText && (
    <span class="tile-count">{countText}</span>
  )}
</a>

<style>
  .category-tile {
    position: relative;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.25rem;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color 0.15s ease-out, box-shadow 0.2s ease;
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .category-tile::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .category-tile:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-card-hover);
  }

  .category-tile:hover::before {
    opacity: 1;
  }

  .tile-icon {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .tile-title {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .tile-description {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .tile-count {
    display: inline-block;
    margin-top: 1rem;
    font-family: 'Commit Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-meta);
  }
</style>
