---
---

<button id="search-trigger" class="search-trigger" aria-label="Search (Cmd+K)" data-search-trigger>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/>
    <path d="m21 21-4.3-4.3"/>
  </svg>
  <span class="search-text">Search</span>
  <kbd class="search-kbd">⌘K</kbd>
</button>

<!-- Search modal -->
<div data-search-modal class="fixed inset-0 z-[100] hidden" role="dialog" aria-label="Search">
  <div class="absolute inset-0 bg-black/50" data-search-backdrop></div>
  <div class="relative max-w-xl mx-auto mt-20 rounded-lg shadow-xl p-6" style="background-color: var(--bg-primary);">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold" style="color: var(--text-primary);">Search</h2>
      <button type="button" class="p-1 rounded-md hover:opacity-70" style="color: var(--text-meta);" data-search-close aria-label="Close search">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="pagefind-container">
      <input
        type="text"
        placeholder="Search field notes…"
        class="w-full px-4 py-2.5 rounded-md border text-sm outline-none focus:ring-2"
        style="border-color: var(--border); color: var(--text-primary); background-color: var(--bg-primary);"
        data-search-input
      />
    </div>
  </div>
</div>

<style>
  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    background: transparent;
    color: var(--text-meta);
    font-size: 0.78rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }

  .search-trigger:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .search-text {
    font-family: 'Inter', sans-serif;
  }

  .search-kbd {
    font-family: 'Commit Mono', monospace;
    font-size: 0.65rem;
    padding: 0.15rem 0.35rem;
    border-radius: 3px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .search-text {
      display: none;
    }
    .search-kbd {
      display: none;
    }
  }
</style>

<script>
  const modal = document.querySelector('[data-search-modal]');
  const closeBtn = document.querySelector('[data-search-close]');
  const backdrop = document.querySelector('[data-search-backdrop]');
  const input = document.querySelector('[data-search-input]') as HTMLInputElement | null;
  const triggers = document.querySelectorAll('[data-search-trigger]');

  function openSearch() {
    modal?.classList.remove('hidden');
    input?.focus();
  }
  function closeSearch() {
    modal?.classList.add('hidden');
  }

  triggers.forEach((t) => t.addEventListener('click', openSearch));
  closeBtn?.addEventListener('click', closeSearch);
  backdrop?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      modal?.classList.contains('hidden') ? openSearch() : closeSearch();
    }
    if (e.key === 'Escape') closeSearch();
  });
</script>
