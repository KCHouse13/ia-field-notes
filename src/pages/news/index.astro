    color: var(--text-meta);
    letter-spacing: 0.03em;
  }
  .tb-reset {
    font-family: 'Commit Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
