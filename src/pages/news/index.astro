  }

  /* ═══════════ COMPACT LIST (default view) ═══════════ */
  .list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-surface);
  }
  .list-row {
    border-top: 1px solid var(--border);
  }
  .list-row:first-child {
    border-top: none;
  }
  .list-row.hidden {
    display: none;
  }
  .row-head {
    width: 100%;
    display: grid;
    grid-template-columns: 12px 1fr auto auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.95rem 1.1rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: 'Inter', -apple-system, sans-serif;
    color: inherit;
    transition: background 0.15s;
  }
  .row-head:hover {
    background: var(--accent-subtle);
  }
  .row-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .row-title {
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    min-width: 0;
  }
  .row-cat {
    font-family: 'Commit Mono', 'Fira Code', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    white-space: nowrap;
  }
  .row-date {
    font-family: 'Commit Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: var(--text-meta);
    white-space: nowrap;
  }
  .row-chev {
    color: var(--text-meta);
    transition: transform 0.2s;
    display: flex;
  }
  .row-chev svg {
    width: 14px;
    height: 14px;
  }
  .list-row.open .row-chev {
    transform: rotate(180deg);
  }
  .row-detail {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.28s ease;
  }
  .list-row.open .row-detail {
    max-height: 320px;
  }
  .row-detail-inner {
    padding: 0 1.1rem 1.1rem 2.85rem;
  }
  .row-detail p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 0.7rem;
  }
  .row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.85rem;
  }
  .mini-tag {
    font-size: 0.68rem;
    color: var(--text-meta);
    background: var(--tag-bg);
    padding: 0.12rem 0.5rem;
    border-radius: 5px;
  }
  .row-source {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .row-source-name {
    font-size: 0.72rem;
    color: var(--text-meta);
  }
  .row-open {
    font-family: 'Commit Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  @media (max-width: 620px) {
    .row-cat {
      display: none;
    }
    .row-detail-inner {
      padding-left: 1.1rem;
    }
  }

  /* ═══════════ CARDS VIEW ═══════════ */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .news-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border-radius: 14px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .news-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
    border-color: transparent;
  }
  .news-card.hidden {
    display: none;
  }
  .news-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.65rem;
  }
  .news-card h3 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.28;
    margin-bottom: 0.4rem;
  }
  .news-card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.52;
    flex: 1;
  }
  .news-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.8rem;
  }
  .news-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.85rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--border);
  }
  .news-source {
    font-size: 0.72rem;
    color: var(--text-meta);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .news-cta {
    font-family: 'Commit Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .news-card:hover .news-cta span {
    transform: translateX(3px);
  }
  .news-cta span {
    transition: transform 0.2s;
  }
  .hide-view {
    display: none !important;
  }

  .empty-state {
    display: none;
    text-align: center;
    padding: 3rem 1rem;
    border: 1px dashed var(--border-strong);
    border-radius: 14px;
    color: var(--text-meta);
  }
  .empty-state.show {
    display: block;
  }
  .empty-state .es-label {
    font-family: 'Commit Mono', 'Fira Code', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .note {
    border-radius: 12px;
    padding: 1rem 1.3rem;
    margin: 1.6rem 0 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--text-secondary);
    background: var(--accent-subtle);
    border-left: 3px solid var(--accent);
  }

  @media (max-width: 880px) {
    .featured-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 720px) {
    .featured-grid,
    .news-grid {
      grid-template-columns: 1fr;
    }
    .latest-item {
      grid-template-columns: 92px 8px 1fr;
    }
    .latest-arrow {
      display: none;
    }
  }
</style>

<script>
  // ═══════════ NEWS EXPLORER ═══════════
  // Filters the server-rendered rows/cards in place (no re-render), then
  // reorders for sort and toggles the list/cards views. All data lives in the
  // markup via data-* attributes, so the page works as a static document and
  // this only enhances it.
  const toolbar = document.getElementById('toolbar');
  const listView = document.getElementById('list-view');
  const cardsView = document.getElementById('cards-view');

  if (toolbar && listView && cardsView) {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const timeSel = document.getElementById('filter-time') as HTMLSelectElement;
    const catSel = document.getElementById('filter-cat') as HTMLSelectElement;
    const sortSel = document.getElementById('filter-sort') as HTMLSelectElement;
    const viewListBtn = document.getElementById('view-list') as HTMLButtonElement;
    const viewCardsBtn = document.getElementById('view-cards') as HTMLButtonElement;
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
    const resultCount = document.getElementById('result-count') as HTMLElement;
    const emptyState = document.getElementById('empty-state') as HTMLElement;
    const provenance = document.getElementById('provenance-note') as HTMLElement;

    const total = listView.children.length;
    const state = { time: 'all', cat: 'all', sort: 'newest', q: '', view: 'list' };

    const monthsAgo = (n: number): Date => {
      const d = new Date();
      d.setMonth(d.getMonth() - n);
      return d;
    };

    function passTime(iso: string): boolean {
      if (state.time === 'all') return true;
      if (state.time === '2026') return iso.startsWith('2026');
      if (state.time === '2025') return iso.startsWith('2025');
      const map: Record<string, number> = { '3m': 3, '6m': 6, '12m': 12 };
      return new Date(iso) >= monthsAgo(map[state.time]);
    }

    function matches(ds: DOMStringMap): boolean {
      if (state.cat !== 'all' && ds.cat !== state.cat) return false;
      if (!passTime(ds.iso || '')) return false;
      if (state.q && !(ds.search || '').includes(state.q)) return false;
      return true;
    }

    function sortContainer(container: HTMLElement): void {
      const nodes = Array.from(container.children) as HTMLElement[];
      nodes.sort((a, b) => {
        if (state.sort === 'newest') return (b.dataset.iso || '').localeCompare(a.dataset.iso || '');
        if (state.sort === 'oldest') return (a.dataset.iso || '').localeCompare(b.dataset.iso || '');
        return (a.dataset.title || '').localeCompare(b.dataset.title || '');
      });
      nodes.forEach((n) => container.appendChild(n));
    }

    function render(): void {
      sortContainer(listView as HTMLElement);
      sortContainer(cardsView as HTMLElement);

      let count = 0;
      const rows = Array.from(listView!.children) as HTMLElement[];
      const cards = Array.from(cardsView!.children) as HTMLElement[];
      rows.forEach((el) => {
        const show = matches(el.dataset);
        el.classList.toggle('hidden', !show);
        if (show) count++;
      });
      cards.forEach((el) => {
        el.classList.toggle('hidden', !matches(el.dataset));
      });

      resultCount.textContent =
        count === total ? `${count} announcements` : `${count} of ${total} announcements`;

      const empty = count === 0;
      emptyState.classList.toggle('show', empty);
      provenance.style.display = empty ? 'none' : '';
      listView!.classList.toggle('hide-view', state.view !== 'list' || empty);
      cardsView!.classList.toggle('hide-view', state.view !== 'cards' || empty);
    }

    function setView(v: string): void {
      state.view = v;
      viewListBtn.classList.toggle('active', v === 'list');
      viewCardsBtn.classList.toggle('active', v === 'cards');
      render();
    }

    // Accordion (list rows are static, so wire up once)
    listView.querySelectorAll('.row-head').forEach((btn) => {
      btn.addEventListener('click', () => {
        const row = btn.closest('.list-row');
        if (!row) return;
        const open = row.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
      });
    });

    timeSel.addEventListener('change', (e) => {
      state.time = (e.target as HTMLSelectElement).value;
      render();
    });
    catSel.addEventListener('change', (e) => {
      state.cat = (e.target as HTMLSelectElement).value;
      render();
    });
    sortSel.addEventListener('change', (e) => {
      state.sort = (e.target as HTMLSelectElement).value;
      render();
    });
    searchInput.addEventListener('input', (e) => {
      state.q = (e.target as HTMLInputElement).value.trim().toLowerCase();
      render();
    });
    viewListBtn.addEventListener('click', () => setView('list'));
    viewCardsBtn.addEventListener('click', () => setView('cards'));
    resetBtn.addEventListener('click', () => {
      state.time = 'all';
      state.cat = 'all';
      state.sort = 'newest';
      state.q = '';
      timeSel.value = 'all';
      catSel.value = 'all';
      sortSel.value = 'newest';
      searchInput.value = '';
      render();
    });

    // "/" focuses search
    document.addEventListener('keydown', (e) => {
      const tag = document.activeElement?.tagName || '';
      if (e.key === '/' && !/INPUT|TEXTAREA|SELECT/.test(tag)) {
        e.preventDefault();
        searchInput.focus();
      }
    });

    render();
  }
</script>
