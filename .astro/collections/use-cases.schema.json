{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "role": {
      "type": "string"
    },
    "industry": {
      "type": "string"
    },
    "readTime": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "role",
    "industry",
    "readTime",
    "excerpt",
    "tags"
  ]
}